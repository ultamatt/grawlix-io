# Shared environment for apps/web and apps/cms
#
# Required (all runtimes):
# - APP_SECRET
#
# Required (containerized runtime with Litestream):
# - AWS_S3_BUCKET
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
#
# Optional:
# - Everything else in this file.

# Core app secret used to derive Strapi secrets by default.
APP_SECRET=replace-me-app-secret

# Object storage target for Litestream replication and optional upload provider.
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Hostname only. No protocol/bucket/path. Example: sfo3.digitaloceanspaces.com
AWS_S3_ENDPOINT=

# Optional: frontend build-time CMS base URL override.
# If unset, frontend falls back to same-origin in production and localhost:1337 in local browser dev.
# PUBLIC_CMS_URL=http://localhost:1337

# Optional runtime overrides (defaults are usually sufficient).
# HOST=0.0.0.0
# WEB_PORT=80
# STRAPI_PORT=1337
# DATABASE_FILENAME=.tmp/data.db
# ALLOWED_HOSTS=localhost,127.0.0.1,grawlix.io,www.grawlix.io
# WEBHOOKS_POPULATE_RELATIONS=false
# STRAPI_TELEMETRY_DISABLED=true
# STRAPI_VERBOSE_ERRORS=false

# Optional explicit Strapi secret overrides.
# Normally unnecessary because these are derived from APP_SECRET.
# APP_KEYS=
# API_TOKEN_SALT=
# ADMIN_JWT_SECRET=
# TRANSFER_TOKEN_SALT=
# JWT_SECRET=

# Optional upload provider tuning.
# AWS_S3_REGION=us-east-1
# AWS_S3_BASE_URL=
# AWS_S3_ACL=public-read
# AWS_S3_FORCE_PATH_STYLE=false
