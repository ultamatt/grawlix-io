# Shared environment for apps/web and apps/cms

# Web (Astro)
# Local dev: point directly at Strapi's port.
# Production (DO): set to your app's root URL, e.g. https://your-app.ondigitalocean.app
#   nginx routes /api/* and /admin to Strapi, so no port suffix needed in production.
PUBLIC_CMS_URL=http://localhost:1337
# Comma-separated hostnames allowed by astro preview in production.
ALLOWED_HOSTS=localhost,127.0.0.1,grawlix.io,www.grawlix.io

# CMS (Strapi)
HOST=0.0.0.0
# WEB_PORT is the public-facing port nginx listens on (docker-compose local default: 80).
# On DO App Platform this is populated from the injected PORT env var in start.sh.
# STRAPI_PORT is the internal port Strapi listens on. In production (behind nginx)
# this port is not exposed publicly; in local docker-compose it may be published
# (e.g. 1337:1337) for direct dev access.
WEB_PORT=80
STRAPI_PORT=1337
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
WEBHOOKS_POPULATE_RELATIONS=false
STRAPI_TELEMETRY_DISABLED=true
DATABASE_FILENAME=.tmp/data.db

# Strapi uploads to S3/Spaces (optional)
# Set AWS_S3_BUCKET to enable S3/Spaces uploads.
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
# Shared by Strapi upload provider and Litestream.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional advanced upload settings:
# AWS_S3_REGION=us-east-1
# AWS_S3_BASE_URL=
# AWS_S3_ACL=public-read
# AWS_S3_FORCE_PATH_STYLE=false

# Litestream (SQLite replication to object storage)
# Required in containerized runtime.
# Startup derives replica URL as: s3://<AWS_S3_BUCKET>/strapi/data
# If using DigitalOcean Spaces, set AWS_S3_ENDPOINT (example: nyc3.digitaloceanspaces.com)
