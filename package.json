{
  "name": "grawlix-io",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "env:generate": "pnpm --filter @grawlix/cms env:generate",
    "env:link": "node scripts/link-env.mjs",
    "predev": "node scripts/link-env.mjs",
    "dev": "turbo run dev",
    "prebuild": "node scripts/link-env.mjs",
    "build": "turbo run build",
    "start": "turbo run start --parallel --filter=@grawlix/web --filter=@grawlix/cms",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3"
  }
}
