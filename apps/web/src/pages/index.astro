---
import { Contact } from "../components/Contact";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { Hero } from "../components/Hero";
import { Services } from "../components/Services";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Grawlix | Web & Mobile App Development">
  <Header />
  <main>
    <Hero client:load />
    <Services client:load />
    <Contact client:load />
  </main>
  <Footer />
</Layout>

<style is:global>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #6366f1;
    color: white;
  }

  .btn-primary:hover {
    background: #4f52d0;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: #f0f0f0;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateY(-1px);
  }

  .section-subtitle {
    color: rgba(240, 240, 240, 0.6);
    font-size: 1.1rem;
    margin: 0 0 3rem;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    background: radial-gradient(ellipse at 50% 0%, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
  }

  .highlight {
    color: #6366f1;
  }

  .hero-content p {
    font-size: 1.25rem;
    color: rgba(240, 240, 240, 0.7);
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Services */
  .services {
    padding: 6rem 0;
  }

  .services h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 2rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .service-card:hover {
    border-color: rgba(99, 102, 241, 0.4);
    transform: translateY(-2px);
  }

  .service-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .service-card p {
    color: rgba(240, 240, 240, 0.6);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Contact */
  .contact {
    padding: 6rem 0;
    background: rgba(255, 255, 255, 0.02);
  }

  .contact h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .contact-form {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(240, 240, 240, 0.8);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    color: #f0f0f0;
    font-size: 1rem;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #6366f1;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(240, 240, 240, 0.3);
  }

  .success-message {
    text-align: center;
    padding: 4rem 2rem;
  }

  .success-message h2 {
    font-size: 2rem;
    margin: 0 0 1rem;
  }
</style>
