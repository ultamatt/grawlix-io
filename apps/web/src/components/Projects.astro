---
const projects = [
  {
    title: "CineSignal",
    href: "https://cinesignal.com",
    image: "/projects/cinesignal-landing.png",
    imageAlt: "CineSignal marketing image showing the Just One Link creative platform hero.",
    category: "Creative platform",
    summary:
      "A media-rich platform for actors, writers, and directors to publish reels, scripts, galleries, and unified professional profiles.",
    highlights: [
      "Product strategy",
      "Search and discovery",
      "Media-heavy UX",
      "Growth landing page",
    ],
  },
  {
    title: "Ditty",
    href: "https://getditty.com",
    image: "/projects/ditty-home.png",
    imageAlt: "Ditty homepage featuring a desktop file transfer product and product screenshot.",
    category: "Desktop product marketing",
    summary:
      "A sharp product site for a cross-platform file transfer tool focused on secure, high-speed cloud handoff for production workflows.",
    highlights: [
      "Product positioning",
      "Desktop software UX",
      "Technical storytelling",
      "Conversion-focused marketing",
    ],
  },
  {
    title: "Big Mac",
    href: "https://mattmoeller.com/blog/big-mac/",
    image: "/projects/big-mac-detail.png",
    imageAlt: "Big Mac utility screenshot showing a desktop app that reads a device MAC address.",
    category: "Desktop utility",
    summary:
      "A small desktop tool built with Rust, Electron, and Neon to solve MAC address lookup issues in Node environments, documented and published through MattMoeller.com.",
    highlights: ["Rust", "Electron", "Neon bindings", "Tooling and debugging"],
  },
];
---

<section id="projects" class="projects">
  <div class="container">
    <div class="projects-header">
      <p class="projects-eyebrow">Selected Work</p>
      <h2>Proof, not promises.</h2>
      <p class="section-subtitle">
        A few of the products, platforms, and websites already in the wild.
      </p>
    </div>

    <div class="projects-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <a href={project.href} class="project-image-link" target="_blank" rel="noopener noreferrer">
              <img src={project.image} alt={project.imageAlt} class="project-image" loading="lazy" />
            </a>

            <div class="project-content">
              <div class="project-copy">
                <p class="project-category">{project.category}</p>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
              </div>

              <ul class="project-highlights" aria-label={`${project.title} capabilities`}>
                {project.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>

              <a
                href={project.href}
                class="btn btn-secondary project-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Visit ${project.title} project`}
              >
                Visit project
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 6rem 0;
  }

  .projects-header {
    max-width: 720px;
    margin-bottom: 3rem;
  }

  .projects-eyebrow {
    margin: 0 0 0.75rem;
    color: #8b92ff;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .projects h2 {
    margin: 0 0 0.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .projects-grid {
    display: grid;
    gap: 2rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02));
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
  }

  .project-image-link {
    display: block;
    min-height: 100%;
    background: #111;
  }

  .project-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
  }

  .project-copy h3 {
    margin: 0 0 0.75rem;
    font-size: 1.65rem;
  }

  .project-copy p:last-child {
    margin: 0;
    color: rgba(240, 240, 240, 0.7);
    line-height: 1.65;
  }

  .project-category {
    margin: 0 0 0.75rem;
    color: rgba(139, 146, 255, 0.95);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .project-highlights {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
  }

  .project-highlights li {
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(240, 240, 240, 0.78);
    font-size: 0.88rem;
  }

  .project-link {
    align-self: flex-start;
  }

  @media (max-width: 900px) {
    .project-card {
      grid-template-columns: 1fr;
    }

    .project-image {
      aspect-ratio: 16 / 10;
    }
  }

  @media (max-width: 640px) {
    .projects {
      padding: 5rem 0;
    }

    .projects h2 {
      font-size: 2rem;
    }

    .project-content {
      padding: 1.25rem;
    }

    .project-copy h3 {
      font-size: 1.35rem;
    }
  }
</style>