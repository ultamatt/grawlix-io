<header class="header">
  <nav class="nav container">
    <a href="/" class="logo">grawlix</a>
    <ul class="nav-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(15, 15, 15, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    color: #f0f0f0;
    letter-spacing: -0.02em;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    text-decoration: none;
    color: rgba(240, 240, 240, 0.7);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #f0f0f0;
  }
</style>
